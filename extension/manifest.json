{
  "manifest_version": 3,
  "name": "PhishGuard AI",
  "version": "2.0",
  "description": "Real-time phishing detection powered by AI",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard AI Scanner"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
